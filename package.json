{
  "name": "patch-pigeon",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "next build",
    "check": "pnpm typecheck && pnpm lint",
    "dev": "next dev",
    "lint": "eslint .",
    "start": "next start",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file-if-exists=.env.local scripts/migrate.mjs",
    "db:push": "node --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "node --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.7.4",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.1.0",
    "@mui/material": "^7.1.0",
    "@mui/material-nextjs": "^7.1.0",
    "bcryptjs": "^2.4.3",
    "date-fns": "4.1.0",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^0.454.0",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "nodemailer": "9.0.3",
    "postgres": "^3.4.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22",
    "@types/nodemailer": "8.0.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "babel-plugin-react-compiler": "latest",
    "drizzle-kit": "0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-react-hooks": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "postcss@<8.5.10": "8.5.10",
      "yaml@>=1.0.0 <1.10.3": "1.10.3"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "nodemailer": "9"
      }
    }
  },
  "packageManager": "pnpm@10.28.2"
}
