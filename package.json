{
  "name": "patch-pigeon",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "next build",
    "check": "pnpm typecheck && pnpm lint",
    "dev": "next dev",
    "lint": "eslint .",
    "start": "next start",
    "test:e2e": "node scripts/e2e.mjs",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:report": "playwright show-report",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file-if-exists=.env.local scripts/migrate.mjs",
    "db:push": "node --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "node --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "1.11.2",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@emotion/cache": "11.14.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@mui/material-nextjs": "^9.1.1",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "0.45.2",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "nodemailer": "9.0.3",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "^22.20.1",
    "@types/nodemailer": "8.0.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-react-hooks": "7.1.1",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "esbuild@<=0.24.2": "0.25.12",
      "postcss@<8.5.10": "8.5.10",
      "yaml@>=1.0.0 <1.10.3": "1.10.3"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "nodemailer": "9"
      }
    }
  },
  "packageManager": "pnpm@10.34.4"
}
